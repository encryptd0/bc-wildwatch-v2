<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="page-main">
  <div class="heatmap-page-wrap">

    <div class="page-header">
      <div class="section-label"><i class="fa-solid fa-map-location-dot"></i> Live Data</div>
      <h1>Campus Incident Heatmap</h1>
      <p>Real-time overlay of reported animal sightings across all Belgium Campus iTversity campuses. Zones light up based on incident volume and severity.</p>
    </div>

    <!-- Legend + total -->
    <div class="heatmap-legend">
      <span class="heatmap-legend-title">Severity:</span>
      <div class="legend-item"><span class="legend-dot" style="background:#10B981"></span> Low</div>
      <div class="legend-item"><span class="legend-dot" style="background:#F59E0B"></span> Medium</div>
      <div class="legend-item"><span class="legend-dot" style="background:#F97316"></span> High</div>
      <div class="legend-item"><span class="legend-dot" style="background:#EF4444"></span> Critical</div>
      <div class="legend-item"><span class="legend-dot legend-dot-empty"></span> No Reports</div>
      <div class="heatmap-legend-count" id="heatmapTotal">Loading...</div>
    </div>

    <!-- Campus tabs -->
    <div class="heatmap-tabs">
      <button class="heatmap-tab active" data-campus="main">Main Campus</button>
      <button class="heatmap-tab" data-campus="north">North Campus</button>
      <button class="heatmap-tab" data-campus="west">West Campus</button>
    </div>

