<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="page-main">
  <div class="container">
    <div class="page-header">
      <h1><i class="fa-solid fa-triangle-exclamation"></i> Report a Sighting</h1>
      <p>Help keep Belgium Campus safe. Fill in the details below and campus security will be notified immediately.</p>
    </div>

    <div class="form-shell">
      <form id="reportForm" class="form-card" novalidate>
        <!-- Reporter Info -->
        <div class="form-section">
          <h3 class="form-section-title"><i class="fa-solid fa-pen-to-square"></i> Your Information</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="reporterName">Full Name <span class="required">*</span></label>
              <input type="text" id="reporterName" name="reporterName" placeholder="e.g. John Doe" required>
              <span class="field-error" id="nameError"></span>
            </div>
            <div class="form-group">
              <label for="reporterEmail">Campus Email <span class="required">*</span></label>
              <input type="email" id="reporterEmail" name="reporterEmail" placeholder="e.g. 601067@<%= reporterDomain %>" required>
              <span class="field-hint">Must be a @<%= reporterDomain %> address</span>
              <span class="field-error" id="emailError"></span>
            </div>
          </div>
        </div>

        <!-- Animal & Location -->
        <div class="form-section">
          <h3 class="form-section-title"><i class="fa-solid fa-paw"></i> Sighting Details</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="animalType">Animal Type <span class="required">*</span></label>
              <select id="animalType" name="animalType" required>
                <option value="">— Select Animal —</option>
                <option value="Snake">Snake</option>
                <option value="Bees/Wasps">Bees/Wasps</option>
                <option value="Ants">Ants</option>
                <option value="Lizard">Lizard</option>
                <option value="Cockroaches">Cockroaches</option>
                <option value="Stray Dog">Stray Dog</option>
                <option value="Stray Cat">Stray Cat</option>
                <option value="Spider">Spider</option>
                <option value="Rat/Mouse">Rat/Mouse</option>
                <option value="Other">Other</option>
              </select>
              <span class="field-error" id="animalError"></span>
            </div>
            <div class="form-group">
              <label for="location">Campus Location <span class="required">*</span></label>
              <select id="location" name="location" required>
                <option value="">— Select Location —</option>
                <optgroup label="── Main Campus: Classrooms ──">
                  <option value="Classroom Alpha">Classroom Alpha</option>
                  <option value="Classroom Beta">Classroom Beta</option>
                  <option value="Classroom Delta">Classroom Delta</option>
                  <option value="Classroom Gamma">Classroom Gamma</option>
                  <option value="Classroom Lambda">Classroom Lambda</option>
                  <option value="Classroom Omega">Classroom Omega</option>
                  <option value="Classroom Omnikron">Classroom Omnikron</option>
                  <option value="Classroom Pi">Classroom Pi</option>
                  <option value="Classroom Roh">Classroom Roh</option>
                  <option value="Classroom Sigma">Classroom Sigma</option>
                  <option value="Classroom Theta">Classroom Theta</option>
                  <option value="Classroom Ypsilon">Classroom Ypsilon</option>
                  <option value="Classroom Zeta">Classroom Zeta</option>
                </optgroup>
                <optgroup label="── Main Campus: Residences ──">
                  <option value="Residence Antwerp">Residence Antwerp</option>
                  <option value="Residence Brussels">Residence Brussels</option>
                  <option value="Residence Eeklo">Residence Eeklo</option>
                  <option value="Residence Genk">Residence Genk</option>
                  <option value="Residence Hasselt">Residence Hasselt</option>
                  <option value="Residence Leuven">Residence Leuven</option>
                </optgroup>
                <optgroup label="── Main Campus: Buildings ──">
                  <option value="Administrations">Administrations</option>
                  <option value="Boardroom">Boardroom</option>
                  <option value="CLC Office">CLC Office</option>
                  <option value="Counsel Offices">Counsel Offices</option>
                  <option value="Cottage">Cottage</option>
                  <option value="Finance">Finance</option>
                  <option value="Lecturers">Lecturers</option>
                  <option value="Library">Library</option>
                  <option value="Reception">Reception</option>
                  <option value="Sales">Sales</option>
                  <option value="Staff Room">Staff Room</option>
                  <option value="Tuck Shop">Tuck Shop</option>
                  <option value="Virtual Room">Virtual Room</option>
                </optgroup>
                <optgroup label="── Main Campus: Outdoor ──">
                  <option value="Basketball Court">Basketball Court</option>
                  <option value="Chess Area">Chess Area</option>
                  <option value="Main Gate">Main Gate</option>
                  <option value="Staff Parking">Staff Parking</option>
                  <option value="Visitors Parking">Visitors Parking</option>
                </optgroup>
                <optgroup label="── North Campus: Classrooms ──">
                  <option value="Classroom Chi">Classroom Chi</option>
                  <option value="Classroom Iota">Classroom Iota</option>
                  <option value="Classroom Kappa 1">Classroom Kappa 1</option>
                  <option value="Classroom Kappa 2">Classroom Kappa 2</option>
                  <option value="Classroom Phi">Classroom Phi</option>
                  <option value="Classroom Psi">Classroom Psi</option>
                </optgroup>
                <optgroup label="── North Campus: Residences ──">
                  <option value="Residence Diepenbeek">Residence Diepenbeek</option>
                  <option value="Residence Dinant">Residence Dinant</option>
                  <option value="Residence Lier">Residence Lier</option>
                  <option value="Residence Liege">Residence Liege</option>
                  <option value="Residence Mechelen">Residence Mechelen</option>
                  <option value="Residence Namur">Residence Namur</option>
                  <option value="Residence Oostende">Residence Oostende</option>
                  <option value="Residence Tienen">Residence Tienen</option>
                  <option value="Residence Turnhout">Residence Turnhout</option>
                </optgroup>
                <optgroup label="── North Campus: Buildings ──">
                  <option value="Cafeteria">Cafeteria</option>
                  <option value="IT Department">IT Department</option>
                  <option value="Laundry">Laundry</option>
                  <option value="Learning Factory">Learning Factory</option>
                  <option value="Procurement">Procurement</option>
                  <option value="Smart Cities">Smart Cities</option>
                </optgroup>
                <optgroup label="── North Campus: Outdoor ──">
                  <option value="Sports Fields">Sports Fields</option>
                  <option value="Student Parking">Student Parking</option>
                </optgroup>
                <optgroup label="── West Campus: Residences ──">
                  <option value="Residence Brugge">Residence Brugge</option>
                  <option value="Residence Brugge Flat">Residence Brugge Flat</option>
                  <option value="Residence Menen">Residence Menen</option>
                  <option value="Residence West House 1">Residence West House 1</option>
                  <option value="Residence West House 2">Residence West House 2</option>
                  <option value="Staff Residences">Staff Residences</option>
                </optgroup>
                <optgroup label="── West Campus: Buildings ──">
                  <option value="Gym &amp; Study Room">Gym &amp; Study Room</option>
                  <option value="Security">Security</option>
                  <option value="Storeroom">Storeroom</option>
                </optgroup>
                <optgroup label="── West Campus: Outdoor ──">
                  <option value="Garden">Garden</option>
                  <option value="Pool">Pool</option>
                </optgroup>
                <optgroup label="── Other ──">
                  <option value="Other">Other</option>
                </optgroup>
              </select>
              <span class="field-error" id="locationError"></span>
            </div>
          </div>

          <!-- Other Animal Description -->
          <div class="form-group" id="otherAnimalGroup" style="display:none;">
            <label for="otherAnimalDescription">Describe the Animal <span class="required">*</span></label>
            <input type="text" id="otherAnimalDescription" name="otherAnimalDescription" placeholder="e.g. Large green bird, approximately 30cm">
          </div>
        </div>

        <!-- Severity -->
        <div class="form-section">
          <h3 class="form-section-title"><i class="fa-solid fa-circle-exclamation"></i> Severity Level <span class="required">*</span></h3>
          <div class="severity-grid">
            <label class="severity-card severity-low">
              <input type="radio" name="severity" value="Low">
              <div class="severity-content">
                <span class="severity-icon"><span class="sev-dot sev-dot-low"></span></span>
                <strong>Low</strong>
                <p>No immediate danger</p>
              </div>
            </label>
            <label class="severity-card severity-medium">
              <input type="radio" name="severity" value="Medium">
              <div class="severity-content">
                <span class="severity-icon"><span class="sev-dot sev-dot-medium"></span></span>
                <strong>Medium</strong>
                <p>Potential risk</p>
              </div>
            </label>
            <label class="severity-card severity-high">
              <input type="radio" name="severity" value="High">
              <div class="severity-content">
                <span class="severity-icon"><span class="sev-dot sev-dot-high"></span></span>
                <strong>High</strong>
                <p>Immediate attention needed</p>
              </div>
            </label>
            <label class="severity-card severity-critical">
              <input type="radio" name="severity" value="Critical">
              <div class="severity-content">
                <span class="severity-icon"><span class="sev-dot sev-dot-critical"></span></span>
                <strong>Critical</strong>
                <p>Danger to life/safety</p>
              </div>
            </label>
          </div>
          <span class="field-error" id="severityError"></span>
        </div>

        <!-- Description -->
        <div class="form-section">
          <h3 class="form-section-title"><i class="fa-solid fa-file-lines"></i> Description</h3>
          <div class="form-group">
            <label for="description">Describe the Incident <span class="required">*</span></label>
            <textarea id="description" name="description" rows="4" maxlength="500" placeholder="Describe what you saw, where exactly, how many animals, any immediate danger..."></textarea>
            <div class="char-counter"><span id="charCount">0</span>/500 characters</div>
            <span class="field-error" id="descError"></span>
          </div>
        </div>

        <!-- Photo Upload -->
        <div class="form-section">
          <h3 class="form-section-title"><i class="fa-solid fa-camera"></i> Photo (Optional)</h3>
          <div class="form-group">
            <label for="photo" class="file-upload-label">
              <div class="file-upload-area" id="fileUploadArea">
                <span class="file-upload-icon"><i class="fa-solid fa-camera"></i></span>
                <span class="file-upload-text">Click to upload or drag &amp; drop</span>
                <span class="file-upload-hint">PNG, JPG, GIF up to 5MB</span>
              </div>
              <input type="file" id="photo" name="photo" accept="image/*" class="file-input">
            </label>
            <div id="photoPreview" class="photo-preview" style="display:none;">
              <img id="previewImg" src="" alt="Preview">
              <button type="button" id="removePhoto" class="btn-remove-photo">&times; Remove</button>
            </div>
          </div>
        </div>

        <div class="form-submit-wrap">
          <button type="submit" class="btn btn-amber btn-full btn-lg" id="submitBtn">
            <span id="submitText"><i class="fa-solid fa-triangle-exclamation"></i> Submit Report</span>
            <span id="submitSpinner" style="display:none;"><i class="fa-solid fa-spinner fa-spin"></i> Submitting...</span>
          </button>
        </div>
      </form>

      <!-- Success Card -->
      <div class="success-card" id="successCard" style="display:none;">
        <i class="fa-solid fa-circle-check success-check-icon"></i>
        <h2>Report Submitted!</h2>
        <p>Campus security has been notified.</p>
        <div class="incident-id-box">
          <span class="incident-id-label">Your Incident ID:</span>
          <span class="incident-id" id="incidentId"></span>
        </div>
        <div class="safety-tip-box" id="safetyTipBox" style="display:none;">
          <div class="safety-tip-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <div class="safety-tip-text" id="safetyTipText"></div>
        </div>
        <p class="success-note">Save your campus email to track this report in <a href="/my-reports">My Reports</a>.</p>
        <div class="success-actions">
          <a href="/my-reports" class="btn btn-secondary"><i class="fa-solid fa-clipboard-list"></i> Track Report</a>
          <button onclick="resetForm()" class="btn btn-outline">Submit Another</button>
        </div>
      </div>
    </div>
  </div>
</main>

<script>window.CAMPUS_DOMAIN = '<%= reporterDomain %>';</script>
<script src="/js/reports.js"></script>
<%- include('partials/footer') %>
